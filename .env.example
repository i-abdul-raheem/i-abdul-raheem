MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=portfolio
ADMIN_PASSWORD=portfolio-admin
PORT=3001

# Local dev only — leave VITE_API_URL empty (Vite proxies /api to port 3001)
VITE_API_URL=

# Tracking links — email notifications
PORTFOLIO_URL=https://i-abdul-raheem.vercel.app
NOTIFY_EMAIL=you@gmail.com

# Option A (recommended): Resend — reliable delivery to Gmail, works on Vercel
# Sign up at https://resend.com — free tier: 100 emails/day
RESEND_API_KEY=
RESEND_FROM=Portfolio Tracker <onboarding@resend.dev>

# Option B: Gmail SMTP — use an App Password (Google Account → Security → App passwords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# EMAIL_FROM=you@gmail.com

# Option C: Custom domain SMTP (may be blocked by Gmail without SPF/DKIM/DMARC)
# SMTP_HOST=mail.yourdomain.com
# SMTP_PORT=465
# SMTP_USER=info@yourdomain.com
# SMTP_PASS=your-password
# EMAIL_FROM=info@yourdomain.com
