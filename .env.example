MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=portfolio
ADMIN_PASSWORD=portfolio-admin
PORT=3001

# Local frontend URL (used for CORS on the API)
CLIENT_URL=http://localhost:5173

# Leave empty locally — Vite proxy handles /api
# Set to your Render API URL in production, e.g. https://portfolio-api.onrender.com
VITE_API_URL=
