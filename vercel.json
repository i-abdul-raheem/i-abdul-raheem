{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "src/locales/**"
    }
  },
  "rewrites": [
    { "source": "/c/:slug", "destination": "/api/r/:slug" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
